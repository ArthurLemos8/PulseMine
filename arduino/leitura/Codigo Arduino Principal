#include <Wire.h>
#define ADXL345 0x53

float x, y, z;

void setup() {
  Serial.begin(9600);
  Wire.begin();
  Serial.println("{\"status\":\"inicializando\"}");
  Wire.beginTransmission(ADXL345);
  Wire.write(0x2D);
  Wire.write(0x08);
  Wire.endTransmission();
  Serial.println("{\"status\":\"pronto\"}");
}

void loop() {
  Wire.beginTransmission(ADXL345);
  Wire.write(0x32);

  if (Wire.endTransmission(false) != 0) {
    Serial.println("{\"erro\":\"sensor_nao_encontrado\"}");
    delay(1000);
    return;
  }

  Wire.requestFrom(ADXL345, 6);

  if (Wire.available() == 6) {
    x = (Wire.read() | (Wire.read() << 8)) * 0.004;
    y = (Wire.read() | (Wire.read() << 8)) * 0.004;
    z = (Wire.read() | (Wire.read() << 8)) * 0.004;

    Serial.print("{\"x\":");
    Serial.print(x, 3);
    Serial.print(",\"y\":");
    Serial.print(y, 3);
    Serial.print(",\"z\":");
    Serial.print(z, 3);
    Serial.println("}");
  } else {
    Serial.println("{\"erro\":\"falha_leitura_bytes\"}");
  }

  delay(100);
}